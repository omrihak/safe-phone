<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_grayscale_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#37474F"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="10dp">

    <TextView
        android:id="@+id/widget_grayscale_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/widget_grayscale_title"
        android:textColor="#FFFFFF"
        android:textSize="15sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/widget_grayscale_subtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="@string/widget_grayscale_subtitle_off"
        android:textColor="#CFD8DC"
        android:textSize="12sp" />

    <TextView
        android:id="@+id/widget_grayscale_indicator_on"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:text="@string/widget_grayscale_indicator_on"
        android:textColor="#B0BEC5"
        android:textSize="11sp"
        android:visibility="gone" />
</LinearLayout>
